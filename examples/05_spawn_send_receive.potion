fn worker() {
    receive {
        on hello(name, caller) {
            print("Hello, " + name)
            send(caller, {ok: "received"})
        }

        on any {
            print("unexpected message")
        }
    }
}

fn main() {
    val proc_id: pid = sp worker()
    send(proc_id, {hello: "Bruce", reply_to: self()})

    receive {
        on ok(text) {
            print(text)
        }

        on any {
            print("no response")
        }
    }
}
