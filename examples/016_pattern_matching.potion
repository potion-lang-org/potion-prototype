val status = :ok

val message = match status {
    :ok => "success"
    :error => "failure"
    _ => "unknown"
}

val value = "outer"

fn main() {
    print(message)

    val response = {:ok, "Potion"}
    val response_message = match response {
        {:ok, value} => value
        {:error, reason} => reason
    }

    print(response_message)

    val result = match {:ok, "inner"} {
        {:ok, value} => value
    }

    print(value)
    print(result)
}
